{
    "name": "jupyter-reasonix",
    "version": "1.0.0",
    "description": "Reasonix Chat — SSH remote server management through conversation, embedded in Jupyter Lab",
    "author": "Reasonix",
    "license": "MIT",
    "main": "lib/index.js",
    "keywords": ["jupyter", "jupyterlab", "jupyterlab-extension", "ssh", "reasonix", "chat"],
    "files": ["lib/**/*", "install.json"],
    "jupyterlab": {
        "extension": true,
        "outputDir": "jupyter_reasonix/static"
    },
    "scripts": {
        "build": "jupyter labextension build .",
        "clean": "rimraf lib"
    },
    "dependencies": {
        "@jupyterlab/application": "^4.0.0",
        "@lumino/widgets": "^2.0.0"
    }
}
